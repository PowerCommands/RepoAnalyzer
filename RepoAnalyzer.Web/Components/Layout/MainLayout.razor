@inherits LayoutComponentBase
@inject IConfiguration Configuration

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Primary">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <img src="favicon.png" alt="@AppName" class="app-logo" />
            <MudText Typo="Typo.h6">@AppName</MudText>
            <MudText Typo="Typo.caption" Class="app-version">v@(Configuration["App:Version"] ?? "1.0.0")</MudText>
        </MudStack>
    </MudAppBar>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private string AppName => Configuration["App:Name"] ?? "Repo Analyzer";
}
