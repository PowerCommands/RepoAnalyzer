@page "/"
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web
@using RepoAnalyzer.Web.Components.Shared
@inject InternalApiClient Api
@inject IJSRuntime Js
@inject IDialogService DialogService
@inject IConfiguration Configuration

<PageTitle>Repo Analyzer</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Repo Analyzer</MudText>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@Error</MudAlert>
}

@if (!string.IsNullOrWhiteSpace(InfoMessage))
{
    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">@InfoMessage</MudAlert>
}

<MudTabs Rounded="true" PanelClass="pa-4" @bind-ActivePanelIndex="ActiveTabIndex">
    <MudTabPanel Text="Dashboard">
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.caption">Total Repositories</MudText>
                    <MudText Typo="Typo.h5">@DashboardTotalRepositories</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.caption">Analyzed / Not Analyzed</MudText>
                    <MudText Typo="Typo.h5">@DashboardAnalyzedCount / @DashboardNotAnalyzedCount</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.caption">Total Vulnerabilities</MudText>
                    <MudText Typo="Typo.h5">@DashboardVulnerabilities</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.caption">Total Outdated</MudText>
                    <MudText Typo="Typo.h5">@DashboardOutdated</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-3">
                    <MudText Typo="Typo.caption">JSON Data Size</MudText>
                    <MudText Typo="Typo.h5">@DashboardJsonSizeMbDisplay MB</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-3 mt-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6">Action Queue</MudText>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@(DashboardNotAnalyzedRepos.Count == 0 || BatchIsRunning)" OnClick="AnalyzeNextNotAnalyzedAsync">Analyze next</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(DashboardNotAnalyzedRepos.Count == 0 || BatchIsRunning)" OnClick="AnalyzeAllNotAnalyzedAsync">Analyze all not analyzed</MudButton>
                </MudStack>
            </MudStack>
            <MudTable Items="DashboardNotAnalyzedRepos" Dense="true" Hover="true" Class="mt-2">
                <HeaderContent>
                    <MudTh>Repository</MudTh>
                    <MudTh>Connection</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@ConnectionName(context.ConnectionId)</MudTd>
                    <MudTd><MudChip Color="Color.Warning" Size="Size.Small">Not Analyzed</MudChip></MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.caption">All repositories are analyzed.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-3 mt-3">
            <MudText Typo="Typo.h6">Highest Risk Repositories</MudText>
            <MudTable Items="DashboardRiskRows" Dense="true" Hover="true" Class="mt-2">
                <HeaderContent>
                    <MudTh>Repository</MudTh>
                    <MudTh>Highest Severity</MudTh>
                    <MudTh>Vulnerabilities</MudTh>
                    <MudTh>Outdated</MudTh>
                    <MudTh>Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.RepositoryName</MudTd>
                    <MudTd>
                        <MudChip Size="Size.Small" Style="@SeverityChipStyle(context.HighestSeverity)">
                            @context.HighestSeverity
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.VulnerabilityCount</MudTd>
                    <MudTd>@context.OutdatedCount</MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Info" OnClick="() => OpenFindingsForRepositoryAsync(context.RepositoryId)">Open findings</MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-3 mt-3">
            <MudText Typo="Typo.h6">Recent Runs</MudText>
            <MudTable Items="RecentRuns" Dense="true" Hover="true" Class="mt-2">
                <HeaderContent>
                    <MudTh>Repository</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Started (UTC)</MudTh>
                    <MudTh>Updated (UTC)</MudTh>
                    <MudTh>Duration</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@RepositoryName(context.RepositoryId)</MudTd>
                    <MudTd><MudChip Color="@RunStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip></MudTd>
                    <MudTd>@context.StartedAtUtc.ToString("u")</MudTd>
                    <MudTd>@context.UpdatedAtUtc.ToString("u")</MudTd>
                    <MudTd>@FormatRunDuration(context)</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.caption">No analysis runs yet.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    </MudTabPanel>

    <MudTabPanel Text="Analyze">
        <MudText Typo="Typo.h6">Run Analysis</MudText>
        <MudGrid Class="mt-2">
            <MudItem xs="12" md="4">
                <MudSelect T="string" Value="AnalyzeConnectionId" ValueChanged="OnAnalyzeConnectionChanged" Label="Connection" Variant="Variant.Outlined">
                    @foreach (var connection in Connections)
                    {
                        <MudSelectItem Value="@connection.Id">@connection.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="string" Value="AnalyzeRepositoryId" ValueChanged="OnAnalyzeRepositoryChanged" Label="Repository" Variant="Variant.Outlined">
                    @foreach (var repo in AnalyzeRepositories)
                    {
                        <MudSelectItem Value="@repo.Id">@RepoSelectorLabel(repo)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-center gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@BatchIsRunning" OnClick="StartAnalyzeFromAnalyzeTab">Analyze</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="@(AnalyzeSnapshot is null || string.IsNullOrWhiteSpace(AnalyzeRepositoryId))" OnClick="DeleteAnalyzeSnapshotAsync">Delete result</MudButton>
            </MudItem>
        </MudGrid>

        @if (BatchIsRunning || BatchCancelRequested || BatchCompletedCount > 0 || BatchFailedCount > 0)
        {
            <MudPaper Class="pa-3 mt-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2">Batch Analysis</MudText>
                    @if (BatchIsRunning)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Disabled="@BatchCancelRequested" OnClick="RequestBatchCancelAsync">Cancel after current repo</MudButton>
                    }
                </MudStack>

                <MudText Typo="Typo.caption" Class="mt-1">@BatchSummaryText</MudText>
                @if (!string.IsNullOrWhiteSpace(BatchCurrentRepoName))
                {
                    <MudText Typo="Typo.caption">Current repo: @BatchCurrentRepoName</MudText>
                }

                <MudProgressLinear Class="mt-2" Color="Color.Primary" Value="@BatchTotalProgressPercent" />
                @if (CurrentAnalyzeRun is not null && CurrentAnalyzeRun.Status is "Running" or "Queued")
                {
                    @if (CurrentAnalyzeRun.ProgressPercent.HasValue)
                    {
                        <MudProgressLinear Class="mt-2" Color="Color.Info" Value="@CurrentAnalyzeRun.ProgressPercent.Value" />
                    }
                    else
                    {
                        <MudProgressLinear Class="mt-2" Color="Color.Info" Indeterminate="true" />
                    }
                }

                @if (BatchCancelRequested)
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-1">Cancellation requested. Batch will stop after current repository finishes.</MudText>
                }
            </MudPaper>
        }

        @if (CurrentAnalyzeRun is not null)
        {
            <MudPaper Class="pa-3 mt-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.subtitle2">Status:</MudText>
                    <MudChip Color="@RunStatusColor(CurrentAnalyzeRun.Status)">@CurrentAnalyzeRun.Status</MudChip>
                    <MudText Typo="Typo.caption">Updated: @CurrentAnalyzeRun.UpdatedAtUtc.ToString("u")</MudText>
                </MudStack>

                @if (CurrentAnalyzeRun.Status is "Running" or "Queued")
                {
                    @if (CurrentAnalyzeRun.ProgressPercent.HasValue)
                    {
                        <MudProgressLinear Class="mt-2" Color="Color.Info" Value="@CurrentAnalyzeRun.ProgressPercent.Value" />
                    }
                    else
                    {
                        <MudProgressLinear Class="mt-2" Color="Color.Info" Indeterminate="true" />
                    }
                }

                <MudText Typo="Typo.caption" Class="mt-1">@AnalyzeStatusText</MudText>

                @if (!string.IsNullOrWhiteSpace(CurrentAnalyzeRun.Error))
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">@CurrentAnalyzeRun.Error</MudText>
                }
            </MudPaper>
        }

        @if (AnalyzeSnapshot is not null)
        {
            <MudExpansionPanels Class="mt-3">
                <MudExpansionPanel Text="@AnalyzeRepoHeader(AnalyzeSnapshot)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Calculate" Size="Size.Small" />
                        <MudText Typo="Typo.caption">@AnalyzeSnapshot.Components.Count</MudText>

                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" />
                        <MudText Typo="Typo.caption">@AnalyzeSnapshot.Outdated.Count</MudText>

                        <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Style="color:#f1c40f" />
                        <MudText Typo="Typo.caption">@SeverityCount(AnalyzeSnapshot, "Low")</MudText>

                        <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Style="color:#ff9800" />
                        <MudText Typo="Typo.caption">@SeverityCount(AnalyzeSnapshot, "Medium")</MudText>

                        <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Style="color:#e74c3c" />
                        <MudText Typo="Typo.caption">@SeverityCount(AnalyzeSnapshot, "High")</MudText>
                    </MudStack>

                    <MudText Typo="Typo.caption">Analyzed at: @AnalyzeSnapshot.AnalyzedAtUtc.ToString("u")</MudText>

                    @foreach (var project in AnalyzeSnapshot.DetectedProjects)
                    {
                        var projectFindings = AnalyzeSnapshot.Vulnerabilities.Concat(AnalyzeSnapshot.Outdated).Where(f => f.ProjectId == project.Id).ToList();
                        var projectComponents = AnalyzeSnapshot.Components.Where(c => c.ProjectId == project.Id).ToList();
                        <MudExpansionPanels Class="mt-3">
                            <MudExpansionPanel Text="@ProjectHeader(project, AnalyzeSnapshot)">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <img src="@ProjectIconPath(project)" alt="@project.ProjectType icon" class="ecosystem-icon" />
                                    <MudText Typo="Typo.caption">Type: @project.ProjectType | Framework: @project.Framework | Version: @project.Version | Language: @project.Language</MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption">Path: @project.Path</MudText>

                                <MudText Typo="Typo.subtitle2" Class="mt-2">Components</MudText>
                                <MudTable Items="projectComponents" Dense="true" RowStyleFunc="@((Component item, int _) => ComponentRowStyle(item, projectFindings))">
                                    <HeaderContent>
                                        <MudTh>Status</MudTh>
                                        <MudTh>Ecosystem</MudTh>
                                        <MudTh>Name</MudTh>
                                        <MudTh>Version</MudTh>
                                        <MudTh>Path</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@ComponentStatus(context, projectFindings)</MudTd>
                                        <MudTd>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <img src="@EcosystemIconPath(context.Ecosystem)" alt="@context.Ecosystem icon" class="ecosystem-icon" />
                                                <span>@context.Ecosystem</span>
                                            </MudStack>
                                        </MudTd>
                                        <MudTd>@context.Name</MudTd>
                                        <MudTd>@context.Version</MudTd>
                                        <MudTd>@context.Path</MudTd>
                                    </RowTemplate>
                                </MudTable>

                                <MudText Typo="Typo.subtitle2" Class="mt-2">Findings</MudText>
                                <MudTable Items="projectFindings" Dense="true">
                                    <HeaderContent>
                                        <MudTh>Type</MudTh>
                                        <MudTh>Package</MudTh>
                                        <MudTh>Installed</MudTh>
                                        <MudTh>Fixed</MudTh>
                                        <MudTh>Severity</MudTh>
                                        <MudTh>Guidance</MudTh>
                                        <MudTh>Tool</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.Type</MudTd>
                                        <MudTd>@context.PackageName</MudTd>
                                        <MudTd>@context.InstalledVersion</MudTd>
                                        <MudTd>@context.FixedVersion</MudTd>
                                        <MudTd>@context.Severity</MudTd>
                                        <MudTd>@context.Advisory</MudTd>
                                        <MudTd>@context.SourceTool</MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </MudTabPanel>

    <MudTabPanel Text="Repos">
        <MudText Typo="Typo.h6">Connection -> Workspace -> Repository</MudText>
        <MudGrid Class="mt-2 mb-2">
            <MudItem xs="12" md="4">
                <MudSelect T="string" Value="RepoFetchConnectionId" ValueChanged="OnRepoFetchConnectionChanged" Label="Connection" Variant="Variant.Outlined">
                    @foreach (var connection in Connections)
                    {
                        <MudSelectItem Value="@connection.Id">@connection.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            @if (IsRepoFetchAdsConnection)
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="string"
                               MultiSelection="true"
                               SelectedValues="RepoFetchSelectedWorkspaces"
                               SelectedValuesChanged="OnRepoFetchWorkspacesChanged"
                               Label="ADS Workspaces (Projects)"
                               Variant="Variant.Outlined">
                        @foreach (var workspaceName in RepoFetchWorkspaceOptions.OrderBy(x => x, StringComparer.OrdinalIgnoreCase))
                        {
                            <MudSelectItem Value="@workspaceName">@workspaceName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="FetchRepositoriesAsync">Fetch repositories</MudButton>
            </MudItem>
        </MudGrid>

        @foreach (var connection in Connections.OrderBy(c => c.Name))
        {
            <MudExpansionPanels Class="mt-3">
                <MudExpansionPanel Text="@ConnectionHeader(connection)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mb-2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@BatchIsRunning"
                                   OnClick="() => StartAnalyzeAllForConnectionAsync(connection.Id)">
                            Analyze all
                        </MudButton>
                    </MudStack>
                    @foreach (var workspace in Workspaces.Where(w => w.ConnectionId == connection.Id))
                    {
                        <MudPaper Class="pa-3 mt-2">
                            <MudText Typo="Typo.subtitle1">@workspace.Name</MudText>

                            @foreach (var repo in SortedReposForWorkspace(connection.Id, workspace.Id))
                            {
                                var latest = GetLatestSnapshot(repo.Id);
                                <MudPaper Class="pa-3 mt-2">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <div>
                                            <MudText Typo="Typo.body1">@repo.Name</MudText>
                                            <MudText Typo="Typo.caption">@repo.Url</MudText>
                                            @if (latest is null)
                                            {
                                                <MudChip Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled" Class="mt-1">Not Analyzed</MudChip>
                                            }
                                            else
                                            {
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Calculate" Size="Size.Small" />
                                                    <MudText Typo="Typo.caption">@latest.Components.Count</MudText>

                                                    <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" />
                                                    <MudText Typo="Typo.caption">@latest.Outdated.Count</MudText>

                                                    <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Style="color:#f1c40f" />
                                                    <MudText Typo="Typo.caption">@SeverityCount(latest, "Low")</MudText>

                                                    <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Style="color:#ff9800" />
                                                    <MudText Typo="Typo.caption">@SeverityCount(latest, "Medium")</MudText>

                                                    <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Style="color:#e74c3c" />
                                                    <MudText Typo="Typo.caption">@SeverityCount(latest, "High")</MudText>
                                                </MudStack>
                                            }
                                        </div>
                                        <MudStack Row="true" Spacing="1">
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Disabled="@BatchIsRunning" OnClick="() => StartAnalyzeFromReposAsync(connection.Id, repo.Id)">@(latest is null ? "Analyze" : "Re-Analyze")</MudButton>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small" Disabled="@(latest is null)" OnClick="() => ViewComponentsForRepoAsync(repo.Id)">View components</MudButton>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="() => DeleteRepositoryAsync(repo.Id)">Delete</MudButton>
                                        </MudStack>
                                    </MudStack>

                                    @if (latest is not null)
                                    {
                                        <MudText Typo="Typo.caption" Class="mt-2">Last analyzed: @latest.AnalyzedAtUtc.ToString("u")</MudText>
                                    }
                                </MudPaper>
                            }
                        </MudPaper>
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </MudTabPanel>

    <MudTabPanel Text="Components">
        <MudText Typo="Typo.h6">Latest 100 Components</MudText>

        <MudGrid Class="mt-2 mb-2">
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="ComponentSearchText" Label="Search (Ecosystem, Package, Version)" Variant="Variant.Outlined" Immediate="true" OnKeyDown="OnComponentsFilterKeyDown" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string?" Value="ComponentSeverityFilter" ValueChanged="OnComponentSeverityFilterChanged" Label="Severity" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((string?)null)">All severities</MudSelectItem>
                    @foreach (var option in ComponentSeverityOptions)
                    {
                        <MudSelectItem Value="@option">@option</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudSelect T="string?" Value="ComponentRepositoryId" ValueChanged="OnComponentRepositoryFilterChanged" Label="Repository" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((string?)null)">All repositories</MudSelectItem>
                    @foreach (var repo in Repositories.OrderBy(r => r.Name))
                    {
                        <MudSelectItem Value="@repo.Id">@repo.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex align-center gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadComponentsAsync">Apply</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearComponentFiltersAsync">Clear</MudButton>
            </MudItem>
        </MudGrid>

        <MudTable Items="ComponentRows" Dense="true" Hover="true" Class="mt-3" RowClick="OnComponentRowClick" RowStyleFunc="@((ComponentRow item, int _) => ComponentListRowStyle(item))" @bind-RowsPerPage="ComponentsRowsPerPage">
            <HeaderContent>
                <MudTh></MudTh>
                <MudTh>Ecosystem</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Installed</MudTh>
                <MudTh>Fixed</MudTh>
                <MudTh>Transitive</MudTh>
                <MudTh>Repository</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <details>
                        <summary style="cursor:pointer;font-size:12px;">Details</summary>
                        <div style="margin-top:8px;">
                            <div><strong>Repository:</strong> @context.RepositoryName</div>
                            <div><strong>Project:</strong> @ProjectName(context.ProjectId)</div>
                            <div><strong>Path:</strong> @context.Path</div>
                            @{
                                var locations = BuildComponentLocations(context);
                                var transitiveRows = BuildTransitiveRows(context.RepositoryId, context.ProjectId);
                            }
                            <div style="margin-top:8px;"><strong>Locations</strong></div>
                            <table style="width:100%;border-collapse:collapse;">
                                <thead>
                                    <tr>
                                        <th style="text-align:left;padding:4px;">Repository</th>
                                        <th style="text-align:left;padding:4px;">Project</th>
                                        <th style="text-align:left;padding:4px;">Path</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var loc in locations)
                                    {
                                        <tr>
                                            <td style="padding:4px;">@loc.RepositoryName</td>
                                            <td style="padding:4px;">@loc.ProjectName</td>
                                            <td style="padding:4px;">@loc.Path</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (transitiveRows.Count > 0)
                            {
                                <div style="margin-top:8px;"><strong>Transitive dependencies (inferred)</strong></div>
                                <table style="width:100%;border-collapse:collapse;">
                                    <thead>
                                        <tr>
                                            <th style="text-align:left;padding:4px;">Status</th>
                                            <th style="text-align:left;padding:4px;">Package</th>
                                            <th style="text-align:left;padding:4px;">Installed</th>
                                            <th style="text-align:left;padding:4px;">Fixed</th>
                                            <th style="text-align:left;padding:4px;">Severity</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in transitiveRows)
                                        {
                                            <tr style="@TransitiveRowInlineStyle(row)">
                                                <td style="padding:4px;">@row.Status</td>
                                                <td style="padding:4px;">@row.PackageName</td>
                                                <td style="padding:4px;">@row.InstalledVersion</td>
                                                <td style="padding:4px;">@row.FixedVersion</td>
                                                <td style="padding:4px;">@row.Severity</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </details>
                </MudTd>
                <MudTd>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <img src="@EcosystemIconPath(context.Ecosystem)" alt="@context.Ecosystem icon" class="ecosystem-icon" />
                        <span>@context.Ecosystem</span>
                    </MudStack>
                </MudTd>
                <MudTd>@context.StatusLabel</MudTd>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.InstalledVersion</MudTd>
                <MudTd>@context.FixedVersion</MudTd>
                <MudTd>
                    <MudBadge Content="@context.TransitiveCount" Color="Color.Info" Dot="false" />
                </MudTd>
                <MudTd>@context.RepositoryName</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 100, 200, 500 }" />
            </PagerContent>
        </MudTable>

        @if (SelectedComponentRow is not null)
        {
            <MudPaper Class="pa-3 mt-3">
                <MudText Typo="Typo.subtitle1">@($"{SelectedComponentRow.Name} ({SelectedComponentRow.InstalledVersion})")</MudText>
                <MudText Typo="Typo.caption">Ecosystem: @SelectedComponentRow.Ecosystem | Status: @SelectedComponentRow.StatusLabel | Fixed: @SelectedComponentRow.FixedVersion</MudText>
                <MudText Typo="Typo.caption">Repository: @SelectedComponentRow.RepositoryName | Project: @ProjectName(SelectedComponentRow.ProjectId)</MudText>
                <MudText Typo="Typo.caption">Path: @SelectedComponentRow.Path</MudText>
                <MudTable Items="SelectedComponentLocations" Dense="true" Class="mt-2">
                    <HeaderContent>
                        <MudTh>Repository</MudTh>
                        <MudTh>Project</MudTh>
                        <MudTh>Path</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.RepositoryName</MudTd>
                        <MudTd>@context.ProjectName</MudTd>
                        <MudTd>@context.Path</MudTd>
                    </RowTemplate>
                </MudTable>

                @if (SelectedComponentTransitiveRows.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-3">Transitive dependencies (inferred)</MudText>
                    <MudTable Items="SelectedComponentTransitiveRows" Dense="true" RowStyleFunc="@((TransitiveDependencyRow item, int _) => TransitiveRowStyle(item))">
                        <HeaderContent>
                            <MudTh>Status</MudTh>
                            <MudTh>Package</MudTh>
                            <MudTh>Installed</MudTh>
                            <MudTh>Fixed</MudTh>
                            <MudTh>Severity</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Status</MudTd>
                            <MudTd>@context.PackageName</MudTd>
                            <MudTd>@context.InstalledVersion</MudTd>
                            <MudTd>@context.FixedVersion</MudTd>
                            <MudTd>@context.Severity</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="Findings">
        <MudText Typo="Typo.h6">Global Findings Index</MudText>

        <MudGrid Class="mt-2">
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="FindingsEcosystem" Label="Ecosystem" Variant="Variant.Outlined" Immediate="true" OnKeyDown="OnFindingsFilterKeyDown" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="FindingsSeverity" Label="Severity" Variant="Variant.Outlined" Immediate="true" OnKeyDown="OnFindingsFilterKeyDown" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string?" Value="FindingsRepoId" ValueChanged="OnFindingsRepositoryFilterChanged" Label="Repository" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                    @foreach (var repo in Repositories)
                    {
                        <MudSelectItem Value="@repo.Id">@repo.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadFindingsAsync">Apply</MudButton>
            </MudItem>
        </MudGrid>

        <MudTable Items="GlobalFindings" Dense="true" Hover="true" Class="mt-3" RowClick="OnFindingRowClick" RowStyleFunc="@((GlobalFinding item, int _) => FindingRowStyle(item))" @bind-RowsPerPage="FindingsRowsPerPage">
            <HeaderContent>
                <MudTh></MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Ecosystem</MudTh>
                <MudTh>Package</MudTh>
                <MudTh>Installed</MudTh>
                <MudTh>Fixed</MudTh>
                <MudTh>Severity</MudTh>
                <MudTh>Affected</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <details>
                        <summary style="cursor:pointer;font-size:12px;">Details</summary>
                        <div style="margin-top:8px;">
                            <div><strong>Package:</strong> @context.PackageName (@context.InstalledVersion)</div>
                            <div><strong>Status:</strong> @EffectiveFindingStatusLabel(context)</div>
                            <div style="margin-top:8px;"><strong>Affected locations</strong></div>
                            <table style="width:100%;border-collapse:collapse;">
                                <thead>
                                    <tr>
                                        <th style="text-align:left;padding:4px;">Repository</th>
                                        <th style="text-align:left;padding:4px;">Project</th>
                                        <th style="text-align:left;padding:4px;">Path</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var loc in context.AffectedLocations)
                                    {
                                        <tr>
                                            <td style="padding:4px;">@RepositoryName(loc.RepositoryId)</td>
                                            <td style="padding:4px;">@ProjectName(loc.ProjectId)</td>
                                            <td style="padding:4px;">@loc.Path</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @{
                                var findingTransitive = BuildFindingTransitiveRows(context);
                            }
                            @if (findingTransitive.Count > 0)
                            {
                                <div style="margin-top:8px;"><strong>Transitive dependencies (inferred)</strong></div>
                                <table style="width:100%;border-collapse:collapse;">
                                    <thead>
                                        <tr>
                                            <th style="text-align:left;padding:4px;">Repository</th>
                                            <th style="text-align:left;padding:4px;">Project</th>
                                            <th style="text-align:left;padding:4px;">Status</th>
                                            <th style="text-align:left;padding:4px;">Package</th>
                                            <th style="text-align:left;padding:4px;">Installed</th>
                                            <th style="text-align:left;padding:4px;">Fixed</th>
                                            <th style="text-align:left;padding:4px;">Severity</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in findingTransitive)
                                        {
                                            <tr style="@TransitiveRowInlineStyle(row)">
                                                <td style="padding:4px;">@row.RepositoryName</td>
                                                <td style="padding:4px;">@row.ProjectName</td>
                                                <td style="padding:4px;">@row.Status</td>
                                                <td style="padding:4px;">@row.PackageName</td>
                                                <td style="padding:4px;">@row.InstalledVersion</td>
                                                <td style="padding:4px;">@row.FixedVersion</td>
                                                <td style="padding:4px;">@row.Severity</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </details>
                </MudTd>
                <MudTd>@context.Type</MudTd>
                <MudTd>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <img src="@EcosystemIconPath(context.Ecosystem)" alt="@context.Ecosystem icon" class="ecosystem-icon" />
                        <span>@context.Ecosystem</span>
                    </MudStack>
                </MudTd>
                <MudTd>@context.PackageName</MudTd>
                <MudTd>@context.InstalledVersion</MudTd>
                <MudTd>@context.FixedVersion</MudTd>
                <MudTd>@EffectiveFindingSeverityLabel(context)</MudTd>
                <MudTd>@context.AffectedLocations.Count</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 100, 200, 500 }" />
            </PagerContent>
        </MudTable>

        @if (SelectedGlobalFinding is not null)
        {
            <MudPaper Class="pa-3 mt-3">
                <MudText Typo="Typo.subtitle1">@($"Affected locations: {SelectedGlobalFinding.PackageName}")</MudText>
                <MudTable Items="SelectedGlobalFinding.AffectedLocations" Dense="true">
                    <HeaderContent>
                        <MudTh>Repository</MudTh>
                        <MudTh>Project</MudTh>
                        <MudTh>Path</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@RepositoryName(context.RepositoryId)</MudTd>
                        <MudTd>@ProjectName(context.ProjectId)</MudTd>
                        <MudTd>@context.Path</MudTd>
                    </RowTemplate>
                </MudTable>

                @if (SelectedFindingTransitiveRows.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-3">Transitive dependencies (inferred)</MudText>
                    <MudTable Items="SelectedFindingTransitiveRows" Dense="true" RowStyleFunc="@((TransitiveDependencyRow item, int _) => TransitiveRowStyle(item))">
                        <HeaderContent>
                            <MudTh>Repository</MudTh>
                            <MudTh>Project</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Package</MudTh>
                            <MudTh>Installed</MudTh>
                            <MudTh>Fixed</MudTh>
                            <MudTh>Severity</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.RepositoryName</MudTd>
                            <MudTd>@context.ProjectName</MudTd>
                            <MudTd>@context.Status</MudTd>
                            <MudTd>@context.PackageName</MudTd>
                            <MudTd>@context.InstalledVersion</MudTd>
                            <MudTd>@context.FixedVersion</MudTd>
                            <MudTd>@context.Severity</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }
    </MudTabPanel>

    <MudTabPanel Text="Connections">
        <MudText Typo="Typo.h6">Connections</MudText>

        <MudPaper Class="pa-4 mt-3">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="ConnectionForm.Name" Label="Name" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect T="ConnectionType" @bind-Value="ConnectionForm.Type" Label="Type" Variant="Variant.Outlined">
                        <MudSelectItem Value="ConnectionType.AzureDevOpsServer">Azure DevOps Server</MudSelectItem>
                        <MudSelectItem Value="ConnectionType.GitHub">GitHub</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudTextField @bind-Value="ConnectionForm.BaseUrlOrOrg" Label="Base URL or Org/User" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ConnectionForm.RawToken" Label="PAT (leave blank to keep current)" Variant="Variant.Outlined" InputType="InputType.Password" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker Date="@TokenExpiryDate" DateChanged="OnExpiryChanged" Label="Token Expires At (optional)" />
                </MudItem>
                <MudItem xs="12" md="2" Class="d-flex align-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveConnectionAsync">Save</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudTable Items="Connections" Dense="true" Hover="true" Class="mt-4">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Target</MudTh>
                <MudTh>Token</MudTh>
                <MudTh>Expiry</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Type</MudTd>
                <MudTd>@context.BaseUrlOrOrg</MudTd>
                <MudTd>@(context.HasToken ? "Encrypted" : "Missing")</MudTd>
                <MudTd>
                    @if (context.TokenExpiresAt.HasValue)
                    {
                        var near = context.TokenExpiresAt.Value <= DateTimeOffset.UtcNow.AddDays(14);
                        <MudChip Color="@(near ? Color.Warning : Color.Success)" Size="Size.Small">@context.TokenExpiresAt.Value.ToString("u")</MudChip>
                    }
                </MudTd>
                <MudTd>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="() => EditConnection(context)">Edit</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="() => DeleteConnectionAsync(context.Id)">Delete</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" OnClick="() => TestConnectionAsync(context.Id)">Test connection</MudButton>
                    @if (ConnectionTestResults.TryGetValue(context.Id, out var testResult))
                    {
                        <MudChip Size="Size.Small" Color="@(testResult.Success ? Color.Success : Color.Error)">@testResult.Message</MudChip>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    <MudTabPanel Text="Tools">
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6">About</MudText>
            <MudText Typo="Typo.body2" Class="mb-2">Repo Analyzer version: <strong>@AppVersion</strong></MudText>
            <MudTable Items="SupportedDistributions" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh></MudTh>
                    <MudTh>Distribution</MudTh>
                    <MudTh>Support</MudTh>
                    <MudTh>Current Runtime</MudTh>
                    <MudTh>Scanner</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <img src="@context.IconPath" alt="@context.Name icon" class="ecosystem-icon" />
                    </MudTd>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@context.SupportLevel</MudTd>
                    <MudTd>@context.RuntimeVersion</MudTd>
                    <MudTd>@context.ScannerTool</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6">Backup</MudText>
            <MudText Typo="Typo.caption">Create or restore a backup zip containing all JSON data files.</MudText>

            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@BackupRestoreBusy" OnClick="CreateBackupAsync">Backup</MudButton>
                </MudItem>
                <MudItem xs="12" md="5" Class="d-flex align-center">
                    <InputFile OnChange="OnRestoreFileSelected" accept=".zip" />
                    <MudText Typo="Typo.caption" Class="ml-2">@RestoreFileName</MudText>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@BackupRestoreBusy" OnClick="RestoreBackupAsync">Restore</MudButton>
                </MudItem>
            </MudGrid>

            @if (BackupRestoreBusy)
            {
                <MudProgressLinear Class="mt-3" Indeterminate="true" Color="Color.Info" />
                <MudText Typo="Typo.caption" Class="mt-1">@BackupRestoreStatusText</MudText>
            }
        </MudPaper>

        <MudText Typo="Typo.h6">Analysis Logs</MudText>
        <MudText Typo="Typo.caption">Latest file: @AnalysisLogs.FileName | Showing @AnalysisLogs.ReturnedLines lines</MudText>

        <MudGrid Class="mt-2 mb-2">
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="LogSearchText" Label="Search text" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string?" @bind-Value="LogLevelFilter" Label="Level" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((string?)null)">All</MudSelectItem>
                    @foreach (var level in LogEntries.Select(x => x.Level).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x))
                    {
                        <MudSelectItem Value="@level">@level</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect T="string" @bind-Value="LogSortBy" Label="Sort by" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Timestamp")">Timestamp</MudSelectItem>
                    <MudSelectItem Value="@("Level")">Level</MudSelectItem>
                    <MudSelectItem Value="@("Provider")">Provider</MudSelectItem>
                    <MudSelectItem Value="@("Step")">Step</MudSelectItem>
                    <MudSelectItem Value="@("Message")">Message</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSwitch @bind-Checked="LogSortDescending" Color="Color.Primary" Label="Desc" />
            </MudItem>
            <MudItem xs="12" md="12" Class="d-flex align-center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReloadLogsAsync">Refresh</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="@Api.GetAnalysisLogDownloadUrl()" Target="_blank" Class="ml-2">Download</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ClearLogsAsync" Class="ml-2">Clear</MudButton>
            </MudItem>
        </MudGrid>

        <MudTable Items="FilteredLogEntries" Dense="true" Hover="true" Class="mt-2" RowsPerPage="100">
            <HeaderContent>
                <MudTh>Timestamp</MudTh>
                <MudTh>Level</MudTh>
                <MudTh>Provider</MudTh>
                <MudTh>Step</MudTh>
                <MudTh>Message</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.TimestampUtc</MudTd>
                <MudTd>@context.Level</MudTd>
                <MudTd>@context.ProviderType</MudTd>
                <MudTd>@context.Step</MudTd>
                <MudTd>@context.Message</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.caption">No log entries found.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudTabPanel>
</MudTabs>

@code {
    private string AppVersion => Configuration["App:Version"] ?? "1.0.0";

    private static readonly List<DistributionInfo> SupportedDistributions =
    [
        new() { Name = "NuGet", IconPath = "/images/nuget.png", SupportLevel = "Supported", RuntimeVersion = ".NET SDK 8.0.418", ScannerTool = "dotnet list package" },
        new() { Name = "NPM", IconPath = "/images/npm.png", SupportLevel = "Supported", RuntimeVersion = "Node v18.20.4 / npm 9.2.0", ScannerTool = "npm audit + npm outdated" },
        new() { Name = "Maven", IconPath = "/images/maven.png", SupportLevel = "Supported", RuntimeVersion = "Apache Maven 3.8.7 / OpenJDK 17.0.18", ScannerTool = "maven-versions + owasp-dependency-check" },
        new() { Name = "PyPI (pip)", IconPath = "/images/pip.png", SupportLevel = "Supported", RuntimeVersion = "Python 3.11.2 / pip 23.0.1", ScannerTool = "pip list + pip-audit" }
    ];

    private string? Error;
    private string? InfoMessage;

    private List<ConnectionView> Connections = new();
    private List<Workspace> Workspaces = new();
    private List<RepositoryEntity> Repositories = new();
    private List<RepoAnalysisSnapshot> Snapshots = new();
    private Dictionary<string, RepoAnalysisSnapshot> LatestSnapshotsByRepo = new(StringComparer.Ordinal);

    private List<Component> Components = new();
    private List<GlobalFinding> GlobalFindings = new();
    private GlobalFinding? SelectedGlobalFinding;
    private List<DashboardRiskRow> DashboardRiskRows = new();
    private List<RepositoryEntity> DashboardNotAnalyzedRepos = new();
    private List<AnalyzeRun> RecentRuns = new();

    private ConnectionUpsertRequest ConnectionForm = new() { Type = ConnectionType.GitHub };
    private DateTime? TokenExpiryDate;
    private readonly Dictionary<string, ConnectionTestResult> ConnectionTestResults = new(StringComparer.Ordinal);

    private string? ComponentSearchText;
    private string? ComponentSeverityFilter;
    private string? ComponentRepositoryId;
    private string? FindingsEcosystem;
    private string? FindingsSeverity;
    private string? FindingsRepoId;
    private AnalysisLogLatestResponse AnalysisLogs = new();
    private string? LogSearchText;
    private string? LogLevelFilter;
    private string LogSortBy = "Timestamp";
    private bool LogSortDescending = true;
    private bool BackupRestoreBusy;
    private string BackupRestoreStatusText = string.Empty;
    private IBrowserFile? RestoreFile;
    private string RestoreFileName = "No file selected";

    private string? AnalyzeConnectionId;
    private string? AnalyzeRepositoryId;
    private AnalyzeRun? CurrentAnalyzeRun;
    private RepoAnalysisSnapshot? AnalyzeSnapshot;
    private bool BatchIsRunning;
    private bool BatchCancelRequested;
    private int BatchTotalCount;
    private int BatchCurrentIndex;
    private int BatchCompletedCount;
    private int BatchFailedCount;
    private string? BatchCurrentRepoName;

    private string? RepoFetchConnectionId;
    private List<string> RepoFetchWorkspaceOptions = new();
    private HashSet<string> RepoFetchSelectedWorkspaces = new(StringComparer.OrdinalIgnoreCase);
    private int ActiveTabIndex;
    private List<ComponentRow> ComponentRows = new();
    private ComponentRow? SelectedComponentRow;
    private List<ComponentLocationRow> SelectedComponentLocations = new();
    private List<TransitiveDependencyRow> SelectedComponentTransitiveRows = new();
    private List<TransitiveDependencyRow> SelectedFindingTransitiveRows = new();
    private List<LogEntryRow> LogEntries = new();
    private Dictionary<string, int> FindingEffectiveWeightByKey = new(StringComparer.Ordinal);
    private Dictionary<string, string> FindingEffectiveStatusByKey = new(StringComparer.Ordinal);
    private Dictionary<string, bool> FindingInheritedFromTransitiveByKey = new(StringComparer.Ordinal);
    private int _componentsRowsPerPage = 100;
    private int _findingsRowsPerPage = 100;
    private bool _prefsLoaded;

    private List<string> ComponentSeverityOptions =>
        ComponentRows
            .Select(x => x.SeverityFilterValue)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderByDescending(SeverityRankForFilter)
            .ThenBy(x => x, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private int DashboardTotalRepositories => Repositories.Count;
    private int DashboardAnalyzedCount => Repositories.Count(r => LatestSnapshotsByRepo.ContainsKey(r.Id));
    private int DashboardNotAnalyzedCount => DashboardTotalRepositories - DashboardAnalyzedCount;
    private int DashboardVulnerabilities => Snapshots.Sum(s => s.Vulnerabilities.Count);
    private int DashboardOutdated => Snapshots.Sum(s => s.Outdated.Count);
    private long DashboardJsonTotalBytes;
    private string DashboardJsonSizeMbDisplay => (DashboardJsonTotalBytes / (1024d * 1024d)).ToString("0.00");

    private int ComponentsRowsPerPage
    {
        get => _componentsRowsPerPage;
        set
        {
            _componentsRowsPerPage = value;
            _ = Js.InvokeVoidAsync("localStorage.setItem", "repoanalyzer.components.rowsperpage", value.ToString());
        }
    }

    private int FindingsRowsPerPage
    {
        get => _findingsRowsPerPage;
        set
        {
            _findingsRowsPerPage = value;
            _ = Js.InvokeVoidAsync("localStorage.setItem", "repoanalyzer.findings.rowsperpage", value.ToString());
        }
    }

    private List<RepositoryEntity> AnalyzeRepositories =>
        string.IsNullOrWhiteSpace(AnalyzeConnectionId)
            ? new List<RepositoryEntity>()
            : Repositories.Where(r => r.ConnectionId == AnalyzeConnectionId).OrderBy(r => r.Name).ToList();

    private bool IsRepoFetchAdsConnection =>
        Connections.FirstOrDefault(x => x.Id == RepoFetchConnectionId)?.Type == ConnectionType.AzureDevOpsServer;

    private string BatchSummaryText =>
        BatchTotalCount <= 0
            ? "No batch in progress."
            : $"Analyzing repo {Math.Min(BatchCurrentIndex, BatchTotalCount)} of {BatchTotalCount}. Completed: {BatchCompletedCount}, Failed: {BatchFailedCount}.";

    private double BatchTotalProgressPercent =>
        BatchTotalCount <= 0
            ? 0
            : Math.Clamp((BatchCompletedCount / (double)BatchTotalCount) * 100d, 0d, 100d);

    private string AnalyzeStatusText =>
        CurrentAnalyzeRun is null
            ? string.Empty
            : string.IsNullOrWhiteSpace(CurrentAnalyzeRun.CurrentStep)
                ? (CurrentAnalyzeRun.CurrentMessage ?? CurrentAnalyzeRun.Status)
                : $"{CurrentAnalyzeRun.CurrentStep}: {CurrentAnalyzeRun.CurrentMessage}";

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _prefsLoaded)
        {
            return;
        }

        _prefsLoaded = true;

        try
        {
            var componentsPref = await Js.InvokeAsync<string?>("localStorage.getItem", "repoanalyzer.components.rowsperpage");
            if (int.TryParse(componentsPref, out var componentsRows) && (componentsRows is 100 or 200 or 500))
            {
                _componentsRowsPerPage = componentsRows;
            }

            var findingsPref = await Js.InvokeAsync<string?>("localStorage.getItem", "repoanalyzer.findings.rowsperpage");
            if (int.TryParse(findingsPref, out var findingsRows) && (findingsRows is 100 or 200 or 500))
            {
                _findingsRowsPerPage = findingsRows;
            }

            StateHasChanged();
        }
        catch
        {
            // Ignore local storage read issues.
        }
    }

    private async Task ReloadAsync()
    {
        Error = null;

        Connections = await Api.GetConnectionsAsync();
        Workspaces = await Api.GetWorkspacesAsync();
        Repositories = await Api.GetRepositoriesAsync();
        Snapshots = await Api.GetSnapshotsAsync();
        var storageStats = await Api.GetDataStorageStatsAsync();
        DashboardJsonTotalBytes = storageStats.TotalJsonBytes;

        LatestSnapshotsByRepo = Snapshots.ToDictionary(x => x.RepositoryId, x => x, StringComparer.Ordinal);

        if (string.IsNullOrWhiteSpace(AnalyzeConnectionId) && Connections.Count > 0)
        {
            AnalyzeConnectionId = Connections[0].Id;
        }

        if (string.IsNullOrWhiteSpace(AnalyzeRepositoryId) && AnalyzeRepositories.Count > 0)
        {
            AnalyzeRepositoryId = AnalyzeRepositories[0].Id;
        }

        if (string.IsNullOrWhiteSpace(RepoFetchConnectionId) && Connections.Count > 0)
        {
            RepoFetchConnectionId = Connections[0].Id;
        }

        await LoadRepoFetchWorkspaceOptionsAsync();

        DashboardNotAnalyzedRepos = Repositories
            .Where(r => !LatestSnapshotsByRepo.ContainsKey(r.Id))
            .OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        DashboardRiskRows = Snapshots
            .Select(s => new
            {
                Snapshot = s,
                HighestSeverity = HighestSeverityForSnapshot(s),
                HasVulnerabilities = s.Vulnerabilities.Count > 0
            })
            .OrderByDescending(x => x.HasVulnerabilities)
            .ThenByDescending(x => SeverityRank(x.HighestSeverity))
            .ThenByDescending(x => x.Snapshot.Vulnerabilities.Count)
            .ThenByDescending(x => x.Snapshot.Outdated.Count)
            .Take(10)
            .Select(x => new DashboardRiskRow
            {
                RepositoryId = x.Snapshot.RepositoryId,
                RepositoryName = RepositoryName(x.Snapshot.RepositoryId),
                HighestSeverity = x.HighestSeverity,
                VulnerabilityCount = x.Snapshot.Vulnerabilities.Count,
                OutdatedCount = x.Snapshot.Outdated.Count
            })
            .ToList();

        RecentRuns = await Api.GetRecentAnalysisRunsAsync(20);

        await ReloadComponentsAsync();
        await ReloadFindingsAsync();
        await ReloadLogsAsync();
        LoadAnalyzeSnapshotForSelection();
    }

