    private static int BaseFindingSortWeight(GlobalFinding finding)
    {
        if (finding.Type == FindingType.Vulnerability)
        {
            return 100 + SeverityRank(NormalizeSeverity(finding.Severity));
        }

        if (finding.Type == FindingType.Outdated)
        {
            return 10;
        }

        return 0;
    }

    private int EffectiveFindingSortWeight(GlobalFinding finding)
        => FindingEffectiveWeightByKey.GetValueOrDefault(finding.Key, BaseFindingSortWeight(finding));

    private int CalculateEffectiveFindingWeight(GlobalFinding finding)
    {
        var direct = BaseFindingSortWeight(finding);
        var transitive = BuildFindingTransitiveRows(finding).Select(x => x.SortWeight).DefaultIfEmpty(0).Max();
        return Math.Max(direct, transitive);
    }

    private bool IsFindingInheritedFromTransitive(GlobalFinding finding)
        => CalculateEffectiveFindingWeight(finding) > BaseFindingSortWeight(finding);

    private string EffectiveFindingSeverityLabel(GlobalFinding finding)
    {
        var weight = EffectiveFindingSortWeight(finding);
        var viaTransitive = FindingInheritedFromTransitiveByKey.GetValueOrDefault(finding.Key, false);
        if (weight >= 100)
        {
            var sev = FindingSeverityFromWeight(weight);
            return viaTransitive
                ? $"Vulnerable ({sev}, via transitive)"
                : $"Vulnerable ({sev})";
        }

        return weight >= 10
            ? (viaTransitive ? "Outdated (via transitive)" : "Outdated")
            : "OK";
    }

    private string CalculateEffectiveFindingStatusLabel(GlobalFinding finding)
        => EffectiveFindingSeverityLabel(finding);

    private string EffectiveFindingStatusLabel(GlobalFinding finding)
        => FindingEffectiveStatusByKey.GetValueOrDefault(finding.Key, EffectiveFindingSeverityLabel(finding));

    private static string BuildComponentStatusLabel(string status, string highestSeverity, bool viaTransitive)
    {
        if (status == "Vulnerable")
        {
            return viaTransitive
                ? $"Vulnerable ({highestSeverity}, via transitive)"
                : $"Vulnerable ({highestSeverity})";
        }

        if (status == "Outdated")
        {
            return viaTransitive ? "Outdated (via transitive)" : "Outdated";
        }

        return "OK";
    }

    private static string FindingSeverityFromWeight(int weight)
    {
        var sevRank = weight - 100;
        return sevRank switch
        {
            >= 4 => "Critical",
            3 => "High",
            2 => "Medium",
            1 => "Low",
            _ => "Unknown"
        };
    }

    private string FindingRowStyle(GlobalFinding finding)
    {
        var effectiveWeight = EffectiveFindingSortWeight(finding);
        if (effectiveWeight >= 100)
        {
            return (effectiveWeight - 100) switch
            {
                >= 4 => "background-color:#ffcdd2;",
                3 => "background-color:#ffd9cc;",
                2 => "background-color:#ffd59e;",
                1 => "background-color:#fff9c4;",
                _ => "background-color:#fff9c4;"
            };
        }

        return effectiveWeight >= 10
            ? "background-color:#f2f2f2;"
            : "background-color:#e8f5e9;";
    }

    private static int SeverityRank(string severity)
        => severity switch
        {
            "Critical" => 4,
            "High" => 3,
            "Medium" => 2,
            "Low" => 1,
            _ => 0
        };

    private static string HighestSeverityForSnapshot(RepoAnalysisSnapshot snapshot)
    {
        if (snapshot.Vulnerabilities.Count == 0)
        {
            return snapshot.Outdated.Count > 0 ? "Outdated" : "OK";
        }

        return snapshot.Vulnerabilities
            .Select(v => NormalizeSeverity(v.Severity))
            .OrderByDescending(SeverityRank)
            .FirstOrDefault() ?? "Unknown";
    }

