    private async Task RestoreBackupAsync()
    {
        if (RestoreFile is null)
        {
            Error = "Choose a backup zip file first.";
            return;
        }

        try
        {
            Error = null;
            InfoMessage = null;
            BackupRestoreBusy = true;
            BackupRestoreStatusText = "Uploading backup zip...";
            StateHasChanged();

            await using var stream = RestoreFile.OpenReadStream(100 * 1024 * 1024);
            var result = await Api.RestoreBackupAsync(RestoreFile.Name, stream);
            BackupRestoreStatusText = "Applying restored data...";

            await ReloadAsync();

            var restoredCount = result?.RestoredFileCount ?? 0;
            InfoMessage = restoredCount > 0
                ? $"Restore completed. Restored {restoredCount} JSON files."
                : "Restore completed. No JSON files were restored from the zip.";
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            BackupRestoreBusy = false;
            BackupRestoreStatusText = string.Empty;
        }
    }

