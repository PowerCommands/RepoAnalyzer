        await Api.DeleteAnalysisAsync(AnalyzeRepositoryId);
        AnalyzeSnapshot = null;
        CurrentAnalyzeRun = null;
        await ReloadAsync();
        InfoMessage = "Analysis result deleted.";
    }

    private async Task PollAnalysisRunAsync(string runId)
    {
        for (var i = 0; i < 240; i++)
        {
            var status = await Api.GetAnalysisRunAsync(runId);
            if (status is null)
            {
                break;
            }

            CurrentAnalyzeRun = status;
            StateHasChanged();

            if (status.Status is "Completed" or "Failed")
            {
                break;
            }

            await Task.Delay(750);
        }

        if (CurrentAnalyzeRun?.Status == "Completed")
        {
            await ReloadAsync();
            LoadAnalyzeSnapshotForSelection();
            InfoMessage = "Analysis completed.";
        }
        else if (CurrentAnalyzeRun?.Status == "Failed")
        {
            Error = CurrentAnalyzeRun.Error ?? "Analysis failed.";
        }
    }

