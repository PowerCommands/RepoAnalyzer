    private string ConnectionHeader(ConnectionView connection)
    {
        var repoCount = Repositories.Count(r => r.ConnectionId == connection.Id);
        return $"{connection.Name} ({ConnectionTypeLabel(connection.Type)}) {repoCount} repositories";
    }

    private static string FormatRunDuration(AnalyzeRun run)
    {
        var end = run.CompletedAtUtc ?? run.UpdatedAtUtc;
        var duration = end - run.StartedAtUtc;

        if (duration.TotalSeconds < 0)
        {
            return "-";
        }

        if (duration.TotalMinutes < 1)
        {
            return $"{Math.Round(duration.TotalSeconds)}s";
        }

        if (duration.TotalHours < 1)
        {
            return $"{Math.Floor(duration.TotalMinutes)}m {duration.Seconds}s";
        }

        return $"{Math.Floor(duration.TotalHours)}h {duration.Minutes}m";
    }

    private static string ConnectionTypeLabel(ConnectionType type)
        => type switch
        {
            ConnectionType.GitHub => "GitHub",
            ConnectionType.AzureDevOpsServer => "Azure DevOps Server",
            _ => type.ToString()
        };

    private static string EcosystemIconPath(string ecosystem)
    {
        if (ecosystem.Equals("NuGet", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/nuget.png";
        }

        if (ecosystem.Equals("npm", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/npm.png";
        }

        if (ecosystem.Equals("maven", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/maven.png";
        }

        if (ecosystem.Equals("python", StringComparison.OrdinalIgnoreCase) ||
            ecosystem.Contains("pip", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/pip.png";
        }

        return "/images/nodejs.png";
    }

    private static string ProjectIconPath(DetectedProject project)
    {
        var projectType = project.ProjectType ?? string.Empty;
        var framework = project.Framework ?? string.Empty;
        var language = project.Language ?? string.Empty;

        if (projectType.Contains("framework", StringComparison.OrdinalIgnoreCase) ||
            framework.StartsWith("net4", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/dotnet-framework.png";
        }

        if (projectType.Contains(".NET", StringComparison.OrdinalIgnoreCase) ||
            language.Equals("C#", StringComparison.OrdinalIgnoreCase) ||
            language.Equals("F#", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/dotnet.png";
        }

        if (language.Equals("JavaScript", StringComparison.OrdinalIgnoreCase) ||
            language.Equals("TypeScript", StringComparison.OrdinalIgnoreCase) ||
            projectType.Contains("node", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/nodejs.png";
        }

        if (language.Equals("Java", StringComparison.OrdinalIgnoreCase) ||
            projectType.Contains("maven", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/java.png";
        }

        if (language.Equals("Python", StringComparison.OrdinalIgnoreCase))
        {
            return "/images/python.png";
        }

        return "/images/nodejs.png";
    }

