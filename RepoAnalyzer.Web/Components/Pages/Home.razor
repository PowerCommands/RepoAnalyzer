        return row.Ecosystem.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
               row.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
               row.InstalledVersion.Contains(searchText, StringComparison.OrdinalIgnoreCase);
    }

