    private List<LogEntryRow> FilteredLogEntries
    {
        get
        {
            IEnumerable<LogEntryRow> query = LogEntries;

            if (!string.IsNullOrWhiteSpace(LogSearchText))
            {
                query = query.Where(x =>
                    x.Message.Contains(LogSearchText, StringComparison.OrdinalIgnoreCase) ||
                    x.Step.Contains(LogSearchText, StringComparison.OrdinalIgnoreCase) ||
                    x.ProviderType.Contains(LogSearchText, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(LogLevelFilter))
            {
                query = query.Where(x => string.Equals(x.Level, LogLevelFilter, StringComparison.OrdinalIgnoreCase));
            }

            query = (LogSortBy, LogSortDescending) switch
            {
                ("Level", true) => query.OrderByDescending(x => x.Level),
                ("Level", false) => query.OrderBy(x => x.Level),
                ("Provider", true) => query.OrderByDescending(x => x.ProviderType),
                ("Provider", false) => query.OrderBy(x => x.ProviderType),
                ("Step", true) => query.OrderByDescending(x => x.Step),
                ("Step", false) => query.OrderBy(x => x.Step),
                ("Message", true) => query.OrderByDescending(x => x.Message),
                ("Message", false) => query.OrderBy(x => x.Message),
                ("Timestamp", false) => query.OrderBy(x => x.TimestampUtc),
                _ => query.OrderByDescending(x => x.TimestampUtc)
            };

            return query.ToList();
        }
    }

    private static LogEntryRow? ParseLogEntry(string line)
    {
        if (string.IsNullOrWhiteSpace(line))
        {
            return null;
        }

        try
        {
            using var doc = JsonDocument.Parse(line);
            var root = doc.RootElement;
            return new LogEntryRow
            {
                TimestampUtc = root.TryGetProperty("TimestampUtc", out var ts) ? ts.GetString() ?? string.Empty : string.Empty,
                Level = root.TryGetProperty("Level", out var lvl) ? lvl.GetString() ?? string.Empty : string.Empty,
                ProviderType = root.TryGetProperty("ProviderType", out var provider) ? provider.GetString() ?? string.Empty : string.Empty,
                Step = root.TryGetProperty("Step", out var step) ? step.GetString() ?? string.Empty : string.Empty,
                Message = root.TryGetProperty("Message", out var message) ? message.GetString() ?? string.Empty : string.Empty
            };
        }
        catch
        {
            return new LogEntryRow
            {
                TimestampUtc = string.Empty,
                Level = "Unknown",
                ProviderType = string.Empty,
                Step = "Unparsed",
                Message = line
            };
        }
    }

