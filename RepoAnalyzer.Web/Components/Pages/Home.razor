    private async Task<bool> ConfirmDangerAsync(string title, string message, string confirmText)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Message)] = message,
            [nameof(ConfirmDialog.ConfirmText)] = confirmText,
            [nameof(ConfirmDialog.CancelText)] = "Cancel",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = DialogService.Show<ConfirmDialog>(title, parameters, options);
        var result = await dialog.Result;
        return !result.Canceled && result.Data is bool confirmed && confirmed;
    }

