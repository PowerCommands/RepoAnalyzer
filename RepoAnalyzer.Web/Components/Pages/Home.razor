    private async Task RunBatchAnalysisAsync(List<RepositoryEntity> repos)
    {
        BatchIsRunning = true;
        BatchCancelRequested = false;
        BatchTotalCount = repos.Count;
        BatchCurrentIndex = 0;
        BatchCompletedCount = 0;
        BatchFailedCount = 0;
        BatchCurrentRepoName = null;
        Error = null;
        InfoMessage = null;

        try
        {
            foreach (var repo in repos)
            {
                BatchCurrentIndex++;
                BatchCurrentRepoName = repo.Name;
                AnalyzeRepositoryId = repo.Id;
                AnalyzeSnapshot = null;
                StateHasChanged();

                var run = await Api.StartAnalysisAsync(repo.Id);
                if (run is null)
                {
                    BatchFailedCount++;
                }
                else
                {
                    var status = await MonitorRunToCompletionAsync(run.Id);
                    if (string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase))
                    {
                        BatchCompletedCount++;
                    }
                    else
                    {
                        BatchFailedCount++;
                    }
                }

                if (BatchCancelRequested)
                {
                    break;
                }
            }

            await ReloadAsync();
            LoadAnalyzeSnapshotForSelection();

            if (BatchCancelRequested)
            {
                InfoMessage = $"Batch stopped after current repository. Completed: {BatchCompletedCount}, Failed: {BatchFailedCount}.";
            }
            else
            {
                InfoMessage = $"Batch completed. Completed: {BatchCompletedCount}, Failed: {BatchFailedCount}.";
            }
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            BatchIsRunning = false;
            BatchCurrentRepoName = null;
            CurrentAnalyzeRun = null;
        }
    }

