    private int SeverityCount(RepoAnalysisSnapshot? snapshot, string severity)
    {
        if (snapshot is null)
        {
            return 0;
        }

        if (severity.Equals("High", StringComparison.OrdinalIgnoreCase))
        {
            return snapshot.Vulnerabilities.Count(v => NormalizeSeverity(v.Severity) is "High" or "Critical");
        }

        return snapshot.Vulnerabilities.Count(v => NormalizeSeverity(v.Severity).Equals(severity, StringComparison.OrdinalIgnoreCase));
    }

    private static string NormalizeSeverity(string? severity)
    {
        if (string.IsNullOrWhiteSpace(severity))
        {
            return "Unknown";
        }

        var value = severity.Trim().ToLowerInvariant();
        return value switch
        {
            "critical" => "Critical",
            "high" => "High",
            "medium" => "Medium",
            "moderate" => "Medium",
            "low" => "Low",
            _ => "Unknown"
        };
    }

    private string ComponentStatus(Component component, List<Finding> projectFindings)
    {
        var vulnerabilities = projectFindings
            .Where(f => f.Type == FindingType.Vulnerability && string.Equals(f.PackageName, component.Name, StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (vulnerabilities.Count > 0)
        {
            var highest = vulnerabilities
                .Select(v => NormalizeSeverity(v.Severity))
                .OrderByDescending(SeverityRank)
                .FirstOrDefault() ?? "Unknown";
            return $"Vulnerable ({highest})";
        }

        var outdated = projectFindings.Any(f => f.Type == FindingType.Outdated && string.Equals(f.PackageName, component.Name, StringComparison.OrdinalIgnoreCase));
        if (outdated)
        {
            return "Outdated";
        }

        return "OK";
    }

    private string ComponentRowStyle(Component component, List<Finding> projectFindings)
    {
        var vulnerabilities = projectFindings
            .Where(f => f.Type == FindingType.Vulnerability && string.Equals(f.PackageName, component.Name, StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (vulnerabilities.Count > 0)
        {
            var maxRank = vulnerabilities.Select(v => SeverityRank(NormalizeSeverity(v.Severity))).DefaultIfEmpty(0).Max();
            return maxRank switch
            {
                >= 4 => "background-color:#ffcdd2;",
                3 => "background-color:#ffd9cc;",
                2 => "background-color:#ffd59e;",
                1 => "background-color:#fff9c4;",
                _ => "background-color:#fff9c4;"
            };
        }

        var outdated = projectFindings.Any(f => f.Type == FindingType.Outdated && string.Equals(f.PackageName, component.Name, StringComparison.OrdinalIgnoreCase));
        if (outdated)
        {
            return "background-color:#f2f2f2;";
        }

        return "background-color:#e8f5e9;";
    }

    private ComponentRow ToComponentRow(Component component)
    {
        var snapshot = LatestSnapshotsByRepo.GetValueOrDefault(component.RepositoryId);
        var findings = snapshot is null
            ? new List<Finding>()
            : snapshot.Vulnerabilities.Concat(snapshot.Outdated)
                .Where(f => f.ProjectId == component.ProjectId && string.Equals(f.PackageName, component.Name, StringComparison.OrdinalIgnoreCase))
                .ToList();

        var vulnerabilities = findings.Where(f => f.Type == FindingType.Vulnerability).ToList();
        var outdated = findings.Where(f => f.Type == FindingType.Outdated).ToList();

        var highestSeverity = vulnerabilities
            .Select(v => NormalizeSeverity(v.Severity))
            .OrderByDescending(SeverityRank)
            .FirstOrDefault() ?? "Unknown";

        var status = vulnerabilities.Count > 0
            ? "Vulnerable"
            : outdated.Count > 0
                ? "Outdated"
                : "OK";
        var severityFilterValue = status switch
        {
            "Vulnerable" => highestSeverity,
            "Outdated" => "Outdated",
            _ => "OK"
        };

        var fixedVersion = vulnerabilities.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v.FixedVersion))?.FixedVersion
            ?? outdated.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v.FixedVersion))?.FixedVersion
            ?? string.Empty;

        var sortWeight = status switch
        {
            "Vulnerable" => 100 + SeverityRank(highestSeverity),
            "Outdated" => 10,
            _ => 0
        };
        var inheritedFromTransitive = false;

        var transitiveRows = BuildTransitiveRows(component.RepositoryId, component.ProjectId);
        var worstTransitive = transitiveRows.OrderByDescending(x => x.SortWeight).FirstOrDefault();
        if (worstTransitive is not null && worstTransitive.SortWeight > sortWeight)
        {
            inheritedFromTransitive = true;
            sortWeight = worstTransitive.SortWeight;
            status = worstTransitive.Status;
            highestSeverity = worstTransitive.Status == "Vulnerable" ? worstTransitive.Severity : "Unknown";
            severityFilterValue = worstTransitive.Status == "Vulnerable"
                ? worstTransitive.Severity
                : worstTransitive.Status;
            if (!string.IsNullOrWhiteSpace(worstTransitive.FixedVersion))
            {
                fixedVersion = worstTransitive.FixedVersion;
            }
        }

        var directNames = snapshot?.Components
            .Where(c => c.ProjectId == component.ProjectId)
            .Select(c => c.Name)
            .ToHashSet(StringComparer.OrdinalIgnoreCase)
            ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var transitiveCount = snapshot is null
            ? 0
            : snapshot.Vulnerabilities.Concat(snapshot.Outdated)
                .Where(f => f.ProjectId == component.ProjectId)
                .Where(f => !directNames.Contains(f.PackageName))
                .Select(f => $"{f.PackageName}|{f.InstalledVersion}")
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Count();

        return new ComponentRow
        {
            Id = component.Id,
            Ecosystem = component.Ecosystem,
            Name = component.Name,
            InstalledVersion = component.Version,
            FixedVersion = fixedVersion,
            RepositoryId = component.RepositoryId,
            RepositoryName = RepositoryName(component.RepositoryId),
            ProjectId = component.ProjectId,
            Path = component.Path,
            Status = status,
            StatusLabel = BuildComponentStatusLabel(status, highestSeverity, inheritedFromTransitive),
            HighestSeverity = highestSeverity,
            SeverityFilterValue = severityFilterValue,
            TransitiveCount = transitiveCount,
            SortWeight = sortWeight
        };
    }

    private List<ComponentLocationRow> BuildComponentLocations(ComponentRow row)
    {
        return Snapshots
            .SelectMany(s => s.Components)
            .Where(c =>
                string.Equals(c.Ecosystem, row.Ecosystem, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(c.Name, row.Name, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(c.Version, row.InstalledVersion, StringComparison.OrdinalIgnoreCase))
            .Select(c => new ComponentLocationRow
            {
                RepositoryId = c.RepositoryId,
                RepositoryName = RepositoryName(c.RepositoryId),
                ProjectName = ProjectName(c.ProjectId),
                Path = c.Path
            })
            .DistinctBy(x => $"{x.RepositoryId}|{x.Path}")
            .OrderBy(x => x.RepositoryName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.Path, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private List<TransitiveDependencyRow> BuildTransitiveRows(string repositoryId, string projectId)
    {
        var snapshot = LatestSnapshotsByRepo.GetValueOrDefault(repositoryId);
        if (snapshot is null)
        {
            return new List<TransitiveDependencyRow>();
        }

        var directNames = snapshot.Components
            .Where(c => c.ProjectId == projectId)
            .Select(c => c.Name)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return snapshot.Vulnerabilities.Concat(snapshot.Outdated)
            .Where(f => f.ProjectId == projectId)
            .Where(f => !directNames.Contains(f.PackageName))
            .GroupBy(f => $"{f.PackageName}|{f.InstalledVersion}", StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var entries = group.ToList();
                var vulns = entries.Where(x => x.Type == FindingType.Vulnerability).ToList();
                var outdated = entries.Where(x => x.Type == FindingType.Outdated).ToList();
                var highest = vulns.Select(v => NormalizeSeverity(v.Severity)).OrderByDescending(SeverityRank).FirstOrDefault() ?? "Unknown";

                var status = vulns.Count > 0
                    ? "Vulnerable"
                    : outdated.Count > 0
                        ? "Outdated"
                        : "OK";

                return new TransitiveDependencyRow
                {
                    RepositoryId = repositoryId,
                    RepositoryName = RepositoryName(repositoryId),
                    ProjectId = projectId,
                    ProjectName = ProjectName(projectId),
                    PackageName = entries[0].PackageName,
                    InstalledVersion = entries[0].InstalledVersion ?? string.Empty,
                    FixedVersion = entries.FirstOrDefault(x => !string.IsNullOrWhiteSpace(x.FixedVersion))?.FixedVersion ?? string.Empty,
                    Status = status,
                    Severity = status == "Vulnerable" ? highest : status,
                    SortWeight = status == "Vulnerable" ? 100 + SeverityRank(highest) : status == "Outdated" ? 10 : 0
                };
            })
            .OrderByDescending(x => x.SortWeight)
            .ThenBy(x => x.PackageName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private List<TransitiveDependencyRow> BuildFindingTransitiveRows(GlobalFinding finding)
    {
        return finding.AffectedLocations
            .SelectMany(loc => BuildTransitiveRows(loc.RepositoryId, loc.ProjectId))
            .GroupBy(x => $"{x.RepositoryId}|{x.ProjectId}|{x.PackageName}|{x.InstalledVersion}", StringComparer.OrdinalIgnoreCase)
            .Select(g => g.First())
            .OrderByDescending(x => x.SortWeight)
            .ThenBy(x => x.RepositoryName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.ProjectName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.PackageName, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool ComponentMatchesSearch(ComponentRow row, string? searchText)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
