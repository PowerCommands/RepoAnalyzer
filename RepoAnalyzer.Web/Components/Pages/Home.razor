    private async Task<string> MonitorRunToCompletionAsync(string runId)
    {
        var status = "Unknown";

        for (var i = 0; i < 240; i++)
        {
            var run = await Api.GetAnalysisRunAsync(runId);
            if (run is null)
            {
                break;
            }

            CurrentAnalyzeRun = run;
            status = run.Status;
            StateHasChanged();

            if (run.Status is "Completed" or "Failed")
            {
                break;
            }

            await Task.Delay(750);
        }

        return status;
    }

    private async Task DeleteAnalyzeSnapshotAsync()
    {
        if (string.IsNullOrWhiteSpace(AnalyzeRepositoryId))
        {
